{
  "name": "@protoburn/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./node": {
      "default": "./src/node.ts"
    },
    "./schema-export": {
      "default": "./src/schema-export.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@protoburn/env": "workspace:*",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@protoburn/config": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5"
  }
}
