{
  "name": "protoburn",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.10",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @protoburn/db db:push",
    "db:generate": "turbo -F @protoburn/db db:generate",
    "db:migrate": "turbo -F @protoburn/db db:migrate",
    "cf:deploy": "turbo -F @protoburn/infra deploy",
    "cf:destroy": "turbo -F @protoburn/infra destroy",
    "cf:setup": "bun run --cwd packages/infra alchemy configure",
    "sync": "bun scripts/sync.ts",
    "sync:watch": "bun scripts/sync.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "version:patch": "npm version patch && git push --follow-tags",
    "version:minor": "npm version minor && git push --follow-tags",
    "version:major": "npm version major && git push --follow-tags"
  },
  "dependencies": {
    "@protoburn/env": "workspace:*",
    "@protoburn/pricing": "workspace:*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@protoburn/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "turbo": "^2.6.3",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
